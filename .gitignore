# Créer .gitignore directement
@'
/vendor/
/node_modules/
.env
.env.backup
.env.production
.env.staging
/bootstrap/cache/*.php
/storage/*.key
/storage/logs/
/storage/framework/cache/data/
/storage/framework/sessions/
/storage/framework/views/
/public/images/profils/
/public/storage
*.log
/build/
/.phpunit.result.cache
.phpunit.cache/
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
'@ | Set-Content ".gitignore" -Encoding UTF8
