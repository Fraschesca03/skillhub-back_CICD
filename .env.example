# Créer .env.example directement
@'
APP_NAME=SkillHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.skillhub.com
APP_CORS_ORIGIN=https://skillhub.com

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=skillhub
DB_USERNAME=skillhub
DB_PASSWORD=

MYSQL_ROOT_PASSWORD=

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=skillhub_messages
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_BLACKLIST_ENABLED=true

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@skillhub.com

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database
LOG_CHANNEL=stderr
LOG_LEVEL=warning
'@ | Set-Content ".env.example" -Encoding UTF8
