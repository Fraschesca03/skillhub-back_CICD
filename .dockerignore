# Créer .dockerignore directement
@'
/vendor/
/node_modules/
.env
.env.*
!.env.example
/tests/
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/
/bootstrap/cache/
.git/
.gitignore
.gitattributes
README.md
CONTRIBUTING.md
*.md
.github/
build/
sonar-project.properties
.idea/
.vscode/
.DS_Store
'@ | Set-Content ".dockerignore" -Encoding UTF8
