# Créer .gitattributes directement
@'
* text=auto
Dockerfile text eol=lf
Dockerfile.* text eol=lf
docker-compose*.yml text eol=lf
.dockerignore text eol=lf
*.sh text eol=lf
*.conf text eol=lf
*.php text eol=lf
*.env.example text eol=lf
artisan text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
'@ | Set-Content ".gitattributes" -Encoding UTF8
